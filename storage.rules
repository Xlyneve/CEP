rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthorizedUser() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'xeve06@gmail.com';
    }

    match /{allPaths=**} {
      allow read, write: if isAuthorizedUser();
    }
  }
}
